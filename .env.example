# ── Cấu hình bảo mật UNC WebApp ────────────────────────────────────────────
# Sao chép file này thành `.env` (đã được .gitignore) và điền giá trị thật.
# docker-compose sẽ tự đọc `.env` ở thư mục gốc và truyền vào container.

# BẮT BUỘC ở production. Sinh một khóa ngẫu nhiên mạnh, ví dụ:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Nếu để trống, app sẽ dùng khóa ngẫu nhiên tạm thời (session mất khi restart).
FLASK_SECRET_KEY=

# Đặt = true khi chạy sau HTTPS (reverse proxy TLS). Local http để false.
COOKIE_SECURE=false

# Chế độ demo UI. Production để false.
DEMO_MODE=false

# OAuth Google — ưu tiên các biến này; nếu để trống sẽ fallback đọc
# backend/client_secret.json (chỉ dùng cho dev, KHÔNG commit file đó).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Phải khớp Authorized redirect URI đã khai báo trong Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost/auth/google/callback
